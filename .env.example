# FastAPI Server Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# Data Directories
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# API Configuration
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
OPEN_METEO_TIMEZONE=auto
OPEN_METEO_REQUEST_TIMEOUT=15

# Available Cities (JSON format)
CITIES={"Berlin": [52.52, 13.41], "Moscow": [55.75, 37.61], "London": [51.50, -0.12]}

# Forecast Parameters
DEFAULT_CITY=Berlin
DEFAULT_START_DATE=2023-01-01
DEFAULT_HORIZON=3

# Model Selection
DEFAULT_MODEL=TabularModel
